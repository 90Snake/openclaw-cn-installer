{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenClaw中文安装助手",
  "version": "0.1.0",
  "identifier": "com.openclaw.cninstaller",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OpenClaw 中文安装助手",
        "width": 1360,
        "height": 920,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "windows": {
      "wix": {
        "language": "zh-CN"
      }
    },
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "createUpdaterArtifacts": false
  }
}
